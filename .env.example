# =============================================================================
# DnD Card Maker — Environment Variables
# Copy this file to .env and fill in values as needed.
# =============================================================================

# ------------------------------- Backend ------------------------------------

# JWT secret key (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# SQLite database path (relative to backend working directory)
SQLITE_PATH=./data/cards.db

# SMTP settings for email (verification, password reset)
SMTP_HOST=smtp.jlwoolf.com
SMTP_PORT=587
SMTP_USER=dnd-card-maker@jlwoolf.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=dnd-card-maker@jlwoolf.com

# Frontend URL used for email links (verification, password reset)
#   Dev:   http://localhost:5173
#   Prod:  http://localhost:8001/dnd-card-maker
FRONTEND_URL=http://localhost:5173

# Dev mail viewer — set to false in production
DEV_MAIL_ENABLED=true

# Cloudflare Turnstile secret key (leave empty to disable CAPTCHA)
# Get keys at https://dash.cloudflare.com/ → Turnstile
TURNSTILE_SECRET_KEY=

# Log level: debug, info, warn, error, critical (default: warn)
LOG_LEVEL=warn

# ------------------------------- Frontend -----------------------------------

# Cloudflare Turnstile site key (leave empty to use test key — dev only)
VITE_TURNSTILE_SITE_KEY=

# Base path for production deployment (e.g. /dnd-card-maker/)
VITE_BASE_PATH=/dnd-card-maker/

# Shared secret for dev/admin pages (/mail, /admin). Must match JWT_SECRET.
# Only used in development mode (import.meta.env.DEV).
VITE_DEV_AUTH=change-me-to-a-random-secret

# API proxy target for Vite dev server (only needed for local dev)
VITE_API_TARGET=http://localhost:8000
