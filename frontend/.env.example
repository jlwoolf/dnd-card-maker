# ---------------------------------------------------------------------------
# DnD Card Maker — Frontend Environment Variables
# Copy this file to .env and fill in values as needed.
# Vite only exposes variables prefixed with VITE_ to client-side code.
# ---------------------------------------------------------------------------

# Cloudflare Turnstile site key for registration CAPTCHA
# Leave unset to use a test key that always passes (dev only).
# Get keys at https://dash.cloudflare.com/ → Turnstile
VITE_TURNSTILE_SITE_KEY=

# Base path for production deployment (e.g. /dnd-card-maker/)
# Not needed in development.
VITE_BASE_PATH=/dnd-card-maker/

# API proxy target for Vite dev server.
# Defaults to http://localhost:8000 — override only if running
# the backend on a different host/port during development.
VITE_API_TARGET=http://localhost:8000

# CORS proxy URL used when capturing card images containing
# cross-origin <img> elements. Set to a self-hosted proxy in
# production to avoid leaking image URLs to third parties.
VITE_CORS_PROXY=
