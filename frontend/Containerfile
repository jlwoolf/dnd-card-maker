FROM node:20-alpine AS build-stage
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
ENV NODE_ENV=production
ARG VITE_TURNSTILE_SITE_KEY
ENV VITE_TURNSTILE_SITE_KEY=$VITE_TURNSTILE_SITE_KEY
ARG VITE_BASE_PATH
ENV VITE_BASE_PATH=$VITE_BASE_PATH
ARG VITE_CORS_PROXY
ENV VITE_CORS_PROXY=$VITE_CORS_PROXY
RUN npm run build

# Stage 2: Production stage
FROM nginx:stable-alpine AS production-stage
ARG VITE_BASE_PATH
ENV VITE_BASE_PATH=$VITE_BASE_PATH
RUN rm -rf /usr/share/nginx/html/*
COPY --from=build-stage /app/dist /usr/share/nginx/html${VITE_BASE_PATH}
COPY nginx.conf /tmp/nginx.conf
RUN BASE_NO_TRAILING="${VITE_BASE_PATH%/}" && \
    sed -e "s|__WITH_SLASH__|${VITE_BASE_PATH}|g" \
        -e "s|__NO_SLASH__|${BASE_NO_TRAILING}|g" \
        /tmp/nginx.conf > /etc/nginx/conf.d/default.conf && \
    rm /tmp/nginx.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]