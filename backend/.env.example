# JWT secret key (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# SQLite database path
SQLITE_PATH=./data/cards.db

# SMTP settings for email (verification, password reset)
SMTP_HOST=smtp.jlwoolf.com
SMTP_PORT=587
SMTP_USER=dnd-card-maker@jlwoolf.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=dnd-card-maker@jlwoolf.com

# Frontend URL (used for verification/reset links in emails)
# Dev (Vite): http://localhost:5173
# Production (compose): http://localhost:8001/dnd-card-maker
FRONTEND_URL=http://localhost:5173

# Dev mail viewer (set to false in production)
DEV_MAIL_ENABLED=true
